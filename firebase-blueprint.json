{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["seeker", "giver", "admin"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "caregivers": {
      "title": "Caregiver",
      "description": "Caregiver specific profile",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "availability": { "type": "string", "enum": ["available", "busy", "offline"] },
        "hourlyRate": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["user_id", "skills", "rating", "location", "availability", "hourlyRate"]
    },
    "bookings": {
      "title": "Booking",
      "description": "Service booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "seeker_id": { "type": "string" },
        "caregiver_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "timestamp": { "type": "number" },
        "totalAmount": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "seeker_id", "caregiver_id", "status", "timestamp", "totalAmount"]
    },
    "learning_modules": {
      "title": "Learning Module",
      "description": "Educational content for caregivers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "video_url": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" }
      },
      "required": ["id", "title", "video_url"]
    },
    "progress": {
      "title": "User Progress",
      "description": "Tracking module completion",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "module_id": { "type": "string" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "number" }
      },
      "required": ["user_id", "module_id", "completed"]
    },
    "escrows": {
      "title": "Escrow",
      "description": "Payment escrow system",
      "type": "object",
      "properties": {
        "booking_id": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["locked", "released"] },
        "timestamp": { "type": "number" }
      },
      "required": ["booking_id", "amount", "status"]
    },
    "alerts": {
      "title": "SOS Alert",
      "description": "Emergency alerts",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "location": { "type": "object" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["user_id", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "users", "description": "User profiles" },
    "/caregivers/{caregiverId}": { "schema": "caregivers", "description": "Caregiver profiles" },
    "/bookings/{bookingId}": { "schema": "bookings", "description": "Bookings" },
    "/learning_modules/{moduleId}": { "schema": "learning_modules", "description": "Learning content" },
    "/progress/{progressId}": { "schema": "progress", "description": "User progress" },
    "/escrows/{escrowId}": { "schema": "escrows", "description": "Escrow records" },
    "/alerts/{alertId}": { "schema": "alerts", "description": "SOS alerts" }
  }
}
