rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public read collections ───────────────────────────────────────────
    // Caregivers and learning modules are readable by unauthenticated clients
    // (discovery / public listing). All writes go through the Node backend
    // using the Admin SDK which bypasses these rules entirely.

    match /caregivers/{id} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    match /learning_modules/{id} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    // ── Backend-only collections ──────────────────────────────────────────
    // These are never touched by client SDKs. The Node backend uses Admin SDK.

    match /users/{id} {
      allow read: if request.auth != null && request.auth.uid == id;
      allow write: if false;
    }

    match /care_requests/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /matches/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /sessions/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /payments/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /ratings/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /sos_alerts/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /module_progress/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /refresh_tokens/{id} {
      allow read: if false;
      allow write: if false;
    }

    // Internal health check — blocked from all clients
    match /_health/{id} {
      allow read, write: if false;
    }

    // Catch-all: deny everything not explicitly listed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
